.dashboard {
  padding-bottom: 64rpx;
}

.hero {
  padding: 34rpx;
  overflow: hidden;
  position: relative;
}

.hero::after {
  content: '';
  position: absolute;
  right: -120rpx;
  top: -120rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(245, 199, 106, 0.12);
}

.hero-top,
.score-row,
.company-main,
.section-head,
.actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow {
  color: #f5c76a;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.title {
  margin-top: 10rpx;
  color: #fff8e8;
  font-size: 56rpx;
  font-weight: 900;
}

.source-badge {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.source-local {
  color: #f5c76a;
  background: rgba(245, 199, 106, 0.12);
}

.source-remote {
  color: #64d89a;
  background: rgba(100, 216, 154, 0.12);
}

.source-fallback {
  color: #ffaf6f;
  background: rgba(255, 175, 111, 0.14);
}

.loading {
  margin-top: 60rpx;
  color: #9aa4b2;
  font-size: 28rpx;
}

.score-row {
  position: relative;
  z-index: 1;
  gap: 28rpx;
  margin-top: 42rpx;
}

.score-ring {
  flex: 0 0 188rpx;
  width: 188rpx;
  height: 188rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(245, 199, 106, 0.66);
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(245, 199, 106, 0.22), rgba(255, 255, 255, 0.03));
  box-shadow: inset 0 0 40rpx rgba(245, 199, 106, 0.12);
}

.score-number {
  color: #f5c76a;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
}

.score-unit {
  margin-top: 4rpx;
  color: #9aa4b2;
  font-size: 22rpx;
}

.score-copy {
  flex: 1;
}

.score-label {
  color: #fff8e8;
  font-size: 30rpx;
  font-weight: 800;
}

.score-summary {
  margin-top: 12rpx;
  color: #c7d0dc;
  font-size: 24rpx;
  line-height: 1.65;
}

.asof {
  margin-top: 14rpx;
  color: #7f8b99;
  font-size: 22rpx;
}

.actions {
  position: relative;
  z-index: 1;
  justify-content: flex-start;
  gap: 20rpx;
  margin-top: 34rpx;
}

.section-head {
  margin: 44rpx 4rpx 20rpx;
}

.section-title {
  color: #fff8e8;
  font-size: 34rpx;
  font-weight: 900;
}

.section-subtitle {
  margin-top: 6rpx;
  color: #8d99a8;
  font-size: 24rpx;
}

.pillar-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.pillar {
  padding: 24rpx;
}

.pillar-score {
  color: #f5c76a;
  font-size: 42rpx;
  font-weight: 900;
}

.pillar-name {
  margin-top: 6rpx;
  color: #fff8e8;
  font-size: 28rpx;
  font-weight: 800;
}

.pillar-desc {
  min-height: 72rpx;
  margin-top: 8rpx;
  color: #8d99a8;
  font-size: 22rpx;
  line-height: 1.5;
}

.bar-track {
  height: 10rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff795f 0%, #f5c76a 100%);
}

.company-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.company-card {
  padding: 26rpx;
}

.ticker {
  color: #f5c76a;
  font-size: 30rpx;
  font-weight: 900;
}

.company-name {
  margin-top: 4rpx;
  color: #fff8e8;
  font-size: 26rpx;
  font-weight: 800;
}

.role {
  max-width: 460rpx;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.company-score {
  color: #fff8e8;
  font-size: 52rpx;
  font-weight: 900;
}

.tag-row {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.signal,
.evidence {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.signal {
  color: #64d89a;
  background: rgba(100, 216, 154, 0.1);
}

.evidence {
  color: #f5c76a;
  background: rgba(245, 199, 106, 0.1);
}

.watch-list {
  padding: 24rpx;
}

.watch-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  color: #c7d0dc;
  font-size: 25rpx;
  line-height: 1.45;
}

.watch-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #ff795f;
  box-shadow: 0 0 18rpx rgba(255, 121, 95, 0.7);
}

.supply-map {
  padding: 24rpx;
}

.map-grid {
  position: relative;
  height: 520rpx;
  border: 1rpx solid rgba(245, 199, 106, 0.15);
  border-radius: 28rpx;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx),
    radial-gradient(circle at 86% 18%, rgba(255, 121, 95, 0.3), transparent 34%),
    radial-gradient(circle at 18% 82%, rgba(100, 216, 154, 0.1), transparent 28%),
    linear-gradient(135deg, rgba(9, 12, 16, 0.96), rgba(22, 28, 36, 0.82));
  background-size: 80rpx 80rpx, 80rpx 80rpx, auto, auto, auto;
}

.map-grid::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(100, 216, 154, 0.07) 0%, transparent 42%, rgba(255, 121, 95, 0.16) 100%);
  pointer-events: none;
}

.map-axis {
  position: absolute;
  z-index: 2;
  color: rgba(255, 248, 232, 0.58);
  font-size: 21rpx;
  letter-spacing: 2rpx;
}

.x-axis {
  right: 24rpx;
  bottom: 18rpx;
}

.y-axis {
  left: 20rpx;
  top: 18rpx;
}

.map-node {
  position: absolute;
  z-index: 3;
  width: 34rpx;
  height: 34rpx;
  transform: translate(-50%, -50%);
}

.node-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.node-pulse {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  opacity: 0.25;
  transform: translate(-50%, -50%);
  animation: pulse 1.8s ease-in-out infinite;
}

.node-label {
  position: absolute;
  left: 28rpx;
  top: -8rpx;
  min-width: 138rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #fff8e8;
  font-size: 21rpx;
  font-weight: 800;
  background: rgba(9, 12, 16, 0.76);
  white-space: nowrap;
}

.map-node.normal .node-core,
.map-node.normal .node-pulse {
  background: #64d89a;
  box-shadow: 0 0 24rpx rgba(100, 216, 154, 0.5);
}

.map-node.watch .node-core,
.map-node.watch .node-pulse {
  background: #f5c76a;
  box-shadow: 0 0 28rpx rgba(245, 199, 106, 0.58);
}

.map-node.tight .node-core,
.map-node.tight .node-pulse {
  background: #ff9f43;
  box-shadow: 0 0 32rpx rgba(255, 159, 67, 0.68);
}

.map-node.critical .node-core,
.map-node.critical .node-pulse {
  background: #ff4d3d;
  box-shadow: 0 0 42rpx rgba(255, 77, 61, 0.82);
}

.node-detail {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.055);
}

.node-detail-head,
.signal-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.node-title {
  color: #fff8e8;
  font-size: 32rpx;
  font-weight: 900;
}

.node-layer {
  margin-top: 6rpx;
  color: #f5c76a;
  font-size: 23rpx;
  font-weight: 700;
}

.risk-score {
  color: #ff795f;
  font-size: 52rpx;
  font-weight: 900;
}

.signal-grid {
  gap: 14rpx;
  margin-top: 22rpx;
}

.signal-grid view {
  flex: 1;
  padding: 18rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.22);
}

.signal-grid text {
  display: block;
  color: #8d99a8;
  font-size: 21rpx;
}

.signal-grid strong {
  display: block;
  margin-top: 7rpx;
  color: #fff8e8;
  font-size: 27rpx;
  font-weight: 900;
}

.reason {
  margin-top: 20rpx;
  color: #c7d0dc;
  font-size: 25rpx;
  line-height: 1.58;
}

@keyframes pulse {
  0% {
    opacity: 0.32;
    transform: translate(-50%, -50%) scale(0.7);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.7);
  }
}
